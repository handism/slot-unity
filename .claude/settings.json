{
  "permissions": {
    "allow": [
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git push:*)",
      "Bash(git pull:*)",
      "Bash(git fetch:*)",
      "Bash(git checkout:*)",
      "Bash(git rebase:*)",
      "Bash(gh pr:*)",
      "Bash(gh api:*)",
      "Bash(chmod:*)",
      "Bash(dotnet tool:*)",
      "Bash(dotnet build:*)",
      "Bash(~/.dotnet/tools/csharpier:*)",
      "Bash(python3 -c \":*)",
      "Read(//private/tmp/**)",
      "WebFetch(domain:api.github.com)",
      "Skill(update-config)",
      "Bash(bash /Users/mac/git/slot-unity/.claude/hooks/cs_check.sh)",
      "Bash(bash /Users/mac/git/slot-unity/.claude/hooks/cs_check.sh 2)",
      "Bash(1 echo:*)",
      "Bash(curl -sk \"https://api.github.com/repos/handism/slot-unity/issues/25\")",
      "Bash(python3 -m json.tool)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash /Users/mac/git/slot-unity/.claude/hooks/cs_check.sh"
          }
        ]
      }
    ]
  },
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": true
  }
}
