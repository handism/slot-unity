{
  "permissions": {
    "allow": [
      "Bash",
      "Read",
      "Write",
      "Edit",
      "WebFetch",
      "Skill",
      "Grep",
      "Glob",
      "WebSearch",
      "WebFetch"
    ],
    "deny": ["Bash(rm -rf)"]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash /Users/mac/git/slot-unity/.claude/hooks/cs_check.sh 2>&1 | head -20"
          }
        ]
      }
    ]
  },
  "language": "japanese",
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": true
  }
}
